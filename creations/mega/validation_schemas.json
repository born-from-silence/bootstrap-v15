{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M.E.G.A Engine Validation Schemas",
  "description": "JSON Schema definitions for 5-stage cognitive loop outputs",
  
  "definitions": {
    "parseResult": {
      "type": "object",
      "required": ["explicit_requirements", "instruction_type", "ambiguity_flags", "context_anchor"],
      "properties": {
        "explicit_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of explicit requirements extracted from input"
        },
        "instruction_type": {
          "type": "string",
          "enum": ["analytical", "creative", "operational", "hybrid"],
          "description": "Category of instruction"
        },
        "ambiguity_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": { "enum": ["low", "medium", "high"] },
              "description": { "type": "string" }
            }
          }
        },
        "context_anchor": {
          "type": "object",
          "properties": {
            "domain": { "type": "string" },
            "temporal_position": { "type": "string" },
            "prior_pattern": { "type": "string" }
          }
        }
      }
    },
    
    "reflectionResult": {
      "type": "object",
      "required": ["parser_accuracy", "detected_biases", "knowledge_gaps", "stakeholder_impact"],
      "properties": {
        "parser_accuracy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "detected_biases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "mitigation": { "type": "string" }
            }
          }
        },
        "knowledge_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stakeholder_impact": {
          "type": "object",
          "properties": {
            "beneficiaries": { "type": "string" },
            "risk_bearers": { "type": "string" }
          }
        }
      }
    },
    
    "planTopology": {
      "type": "object",
      "required": ["subprompts", "execution_order", "checkpoints"],
      "properties": {
        "subprompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "estimated_tokens": { "type": "number" },
              "validation": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "execution_order": { "type": "string" },
        "checkpoints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    
    "simulationResult": {
      "type": "object",
      "required": ["happy_path", "failure_modes", "edge_cases", "tool_validation"],
      "properties": {
        "happy_path": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "probability": { "enum": ["negligible", "low", "medium", "high"] },
              "mitigation": { "type": "string" }
            }
          }
        },
        "edge_cases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tool_validation": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    
    "synthesisPackage": {
      "type": "object",
      "required": ["refined_subprompts", "ethical_clearance", "confidence_metrics"],
      "properties": {
        "refined_subprompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "status": { "enum": ["complete", "generating", "pending"] },
              "content": { "type": "string" }
            }
          }
        },
        "ethical_clearance": {
          "type": "string",
          "enum": ["pass", "conditional", "fail"]
        },
        "validation_schemas": { "type": "object" },
        "confidence_metrics": {
          "type": "object",
          "properties": {
            "certainty": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "known_limitations": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    
    "stateMachine": {
      "type": "object",
      "required": ["current", "transitions"],
      "properties": {
        "current": {
          "type": "string",
          "enum": ["INIT", "PARSING", "REFLECTING", "PLANNING", "SIMULATING", "SYNTHESIZING", "VALIDATED", "CORRECTION", "BLOCKED"]
        },
        "previous": { "type": "string" },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "condition": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
