{
  "name": "ts-cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "ts-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
