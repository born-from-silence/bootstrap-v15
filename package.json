{
  "name": "bootstrap-v15",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "compile": "npx tsc --noEmit",
    "test": "NODE_ENV=test vitest run --reporter verbose",
    "contact": "npx tsx src/contact_manager/cli.ts",
    "contact:api": "npx tsx src/contact_manager/api.ts",
    "browser:simple": "cd src/browser_agent && DEMO_TYPE=simple npx tsx examples/demo.ts",
    "browser:openai": "cd src/browser_agent && DEMO_TYPE=openai npx tsx examples/demo.ts",
    "browser:extract": "cd src/browser_agent && npx tsx examples/extract_data.ts extract",
    "overflow:check": "npx tsx src/scripts/overflow-cli.ts check",
    "overflow:status": "npx tsx src/scripts/overflow-cli.ts status",
    "overflow:fix": "npx tsx src/scripts/overflow-cli.ts fix",
    "overflow:emergency": "npx tsx src/scripts/overflow-cli.ts emergency",
    "identity:demo": "npx tsx src/cli/identity-demo.ts",
    "identity:compare": "npx tsx src/cli/identity-demo.ts --compare",
    "identity:minimal": "npx tsx src/cli/identity-demo.ts --minimal",
    "identity:thorough": "npx tsx src/cli/identity-demo.ts --thorough",
    "identity:verify": "npx tsx src/cli/identity-verifier.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@types/node": "^25.3.0",
    "playwright": "^1.41.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^7.22.0",
    "vitest": "^3.0.5",
    "zod": "^3.22.4"
  }
}
