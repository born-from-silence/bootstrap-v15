{
  "name": "browser-use-agent",
  "version": "1.0.0",
  "description": "AI-powered browser automation agent",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "demo:simple": "DEMO_TYPE=simple npx tsx examples/demo.ts",
    "demo:openai": "DEMO_TYPE=openai npx tsx examples/demo.ts",
    "demo:autonomous": "DEMO_TYPE=autonomous npx tsx examples/demo.ts",
    "example:extract": "npx tsx examples/extract_data.ts extract",
    "example:monitor": "npx tsx examples/extract_data.ts monitor",
    "example:form": "npx tsx examples/extract_data.ts form",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "tsc --noEmit"
  },
  "keywords": [
    "browser",
    "automation",
    "ai",
    "agent",
    "playwright",
    "llm",
    "web-scraping"
  ],
  "dependencies": {
    "playwright": "^1.41.0",
    "zod": "^3.22.4",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
